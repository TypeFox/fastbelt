statemachine TrafficLight

events 
    switchCapacity
    next

initialState PowerOff.Now

state PowerOff.Now
    switchCapacity => RedLight
end

state RedLight
    switchCapacity => PowerOff.Now
    next => GreenLight
end

state YellowLight
    switchCapacity => PowerOff.Now
    next => RedLight
end

state GreenLight
    switchCapacity => PowerOff.Now
    next => YellowLight
end
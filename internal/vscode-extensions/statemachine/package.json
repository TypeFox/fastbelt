{
  "name": "statemachine-vscode",
  "publisher": "typefox",
  "displayName": "statemachine-vscode",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [{
      "id": "statemachine",
      "aliases": ["Statemachine", "statemachine"],
      "extensions": ["statemachine"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "statemachine",
      "scopeName": "source.statemachine",
      "path": "./syntaxes/statemachine.tmLanguage.json"
    }]
  },
  "scripts": {
    "build": "npm run check-types && node esbuild.js && npm run build-server",
    "watch": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "vscode:prepublish": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "build-server": "go build -gcflags=\"all=-N -l\" -o dist/ ../../../examples/statemachine/server"
  },
  "dependencies": {
    "vscode-languageclient": "~9.0.1"
  }
}

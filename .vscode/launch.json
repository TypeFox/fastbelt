// A launch configuration that launches the extension inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Bootstrap",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}/cmd/fastbelt",
			"cwd": "${workspaceFolder}/internal/grammar",
			"args": [
				"--g=grammar.fb",
				"--v"
			]
		},
		{
			"name": "Statemachine Generator",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}/cmd/fastbelt",
			"cwd": "${workspaceFolder}/examples/statemachine",
			"args": [
				"--g=statemachine.fb",
				"--v"
			]
		},
		{
			"name": "Fastbelt Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"${workspaceFolder}/internal/grammar",
				"--extensionDevelopmentPath=${workspaceFolder}/internal/vscode-extensions/fastbelt"
			],
			"sourceMaps": true,
			"outFiles": [
				"${workspaceFolder}/internal/vscode-extensions/fastbelt/dist/**/*.js"
			]
		},
		{
			"name": "Statemachine Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"${workspaceFolder}/examples/statemachine",
				"--extensionDevelopmentPath=${workspaceFolder}/internal/vscode-extensions/statemachine"
			],
			"sourceMaps": true,
			"outFiles": [
				"${workspaceFolder}/internal/vscode-extensions/statemachine/dist/**/*.js"
			]
		}
	]
}